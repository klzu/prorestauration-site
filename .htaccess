# ================================================================
# ProRestauration.fr — .htaccess
# Sécurité + Performance + Redirections
# ================================================================

# ── HTTPS FORCÉ ─────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # non-www → www
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteCond %{HTTPS} on
  RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ── HEADERS DE SÉCURITÉ ─────────────────────────────────────────
<IfModule mod_headers.c>
  # Empêche l'intégration dans une iframe (clickjacking)
  Header always set X-Frame-Options "SAMEORIGIN"

  # Empêche le MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Contrôle les infos de referrer envoyées aux sites tiers
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Désactive les fonctionnalités navigateur non utilisées
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"

  # Force HTTPS pour 1 an (HSTS) — activer une fois HTTPS stable
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Supprime le header "X-Powered-By" révélateur de techno
  Header always unset X-Powered-By
  Header always unset Server
</IfModule>

# ── BLOQUER L'ACCÈS AUX FICHIERS SENSIBLES ──────────────────────
# .git — historique complet, tokens, config
RedirectMatch 403 /\.git(/.*)?$

# Fichiers de config, déploiement, secrets
<FilesMatch "(^\.env|^\.htpasswd|deploy\.php|\.cpanel\.yml|wp-config\.php|config\.php|\.bak|\.log|\.sql|\.pem|\.key)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Fichiers cachés (dot-files) sauf .well-known (SSL/ACME)
RedirectMatch 403 /\.(?!well-known)

# ── INTERDIRE LE LISTING DES DOSSIERS ───────────────────────────
Options -Indexes

# ── CACHE NAVIGATEUR (performance) ──────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # CSS / JS versionnés → 1 an
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"

  # Images → 6 mois
  ExpiresByType image/webp                "access plus 6 months"
  ExpiresByType image/jpeg                "access plus 6 months"
  ExpiresByType image/png                 "access plus 6 months"
  ExpiresByType image/svg+xml             "access plus 6 months"
  ExpiresByType image/x-icon              "access plus 6 months"

  # Fonts → 1 an
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"

  # HTML → revalidation rapide
  ExpiresByType text/html                 "access plus 1 hour"
</IfModule>

# ── COMPRESSION GZIP ────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── PAGE D'ERREUR PERSONNALISÉE ──────────────────────────────────
ErrorDocument 404 /404.html
